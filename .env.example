# Heyo configuration (copy to .env)

# API server
HEYO_HOST=0.0.0.0
HEYO_PORT=8000

# Directory the files agent is allowed to operate in
HEYO_WORKSPACE=./workspace

# Model serving (OpenAI-compatible endpoints)
OLLAMA_BASE_URL=http://localhost:11434/v1
VLLM_BASE_URL=http://localhost:8001/v1

# Qdrant
QDRANT_URL=http://localhost:6333

# Path to role->model mapping (generated by scripts/fit_models.py)
HEYO_MODELS_FILE=./models.yaml

# MCP servers config
HEYO_MCP_FILE=./mcp.json

# Skills directory
HEYO_SKILLS_DIR=./skills

# Voice — server side (/voice/transcribe, /voice/speak)
HEYO_STT_MODEL=small         # faster-whisper size: tiny/base/small/medium
HEYO_STT_DEVICE=cpu          # cpu (default — the LLM owns the GPU) or cuda
#HEYO_STT_LANGUAGE=en        # unset = auto-detect
HEYO_PIPER_VOICE=en_US-lessac-medium

# Voice — client (apps/voice/client.py)
HEYO_API_URL=http://localhost:8000
HEYO_HOTKEY=ctrl+alt+h       # global push-to-talk ("off" to disable)
HEYO_WAKE=auto               # auto|vosk|oww|off — vosk spots the word "heyo"
HEYO_WAKE_MODEL=hey_jarvis   # openWakeWord model (oww engine only)

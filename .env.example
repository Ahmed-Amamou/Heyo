# Heyo configuration (copy to .env)

# API server
HEYO_HOST=0.0.0.0
HEYO_PORT=8000

# Directory the files agent is allowed to operate in
HEYO_WORKSPACE=./workspace

# Model serving (OpenAI-compatible endpoints)
OLLAMA_BASE_URL=http://localhost:11434/v1
VLLM_BASE_URL=http://localhost:8001/v1

# Qdrant
QDRANT_URL=http://localhost:6333

# Path to role->model mapping (generated by scripts/fit_models.py)
HEYO_MODELS_FILE=./models.yaml

# MCP servers config
HEYO_MCP_FILE=./mcp.json

# Skills directory
HEYO_SKILLS_DIR=./skills

# Voice client
HEYO_API_URL=http://localhost:8000
HEYO_WAKE_MODEL=hey_jarvis   # placeholder until custom "heyo" model is trained
HEYO_WHISPER_MODEL=small
HEYO_PIPER_VOICE=en_US-lessac-medium
